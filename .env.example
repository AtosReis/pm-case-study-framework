# PM Case Study Generator - optional LLM configuration
#
# The app works without any API key.
# Add one or more keys below only if you want to enable LLM review features.
#
# Never commit a real .env file with secrets.

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/auto
